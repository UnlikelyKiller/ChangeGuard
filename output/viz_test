            const riskVal = document.getElementById('riskFilter').value;
            
            const filteredNodes = raw_nodes.filter(n => {
                let commMatch = (commVal === 'all') || (n.community == commVal);
                let riskMatch = true;
                if (riskVal === 'high') riskMatch = n.risk_score > 0.7;
