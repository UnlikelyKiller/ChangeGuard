        });

        const nodes = new vis.DataSet(raw_nodes.map(n => {
            let bgColor = '#4E79A7';
            if (n.risk_score > 0.7) {
                bgColor = '#ff5555';
            } else if (n.community !== null && n.community !== undefined) {
                bgColor = colorPalette[Math.abs(n.community) % colorPalette.length];
            }
            return {
                id: n.id,
                label: n.label,
                group: n.community,
                color: {
                    background: bgColor,
                    border: '#2a2a4e'
                },
